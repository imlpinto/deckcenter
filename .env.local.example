# ============================================================
# TCGMarket — Variables de entorno
# Copia este archivo como .env.local y rellena los valores
# ============================================================

# --- Supabase ---
# Obtén estos valores en: https://app.supabase.com → Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://tu-proyecto.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOi...

# --- TCGdex API (api.tcgdex.net) ---
# ✅ Completamente gratuita, sin registro, sin API key
# No necesitas configurar nada aquí — funciona out of the box
# Documentación: https://tcgdex.dev
#
# (Opcional a futuro) Scrydex — para precios avanzados de mercado
# NEXT_PUBLIC_SCRYDEX_API_KEY=
# NEXT_PUBLIC_SCRYDEX_TEAM_ID=

# --- App ---
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_APP_NAME=TCGMarket

# --- Cron ---
# Genera un string aleatorio seguro, ej: openssl rand -hex 32
CRON_SECRET=cambia-esto-por-un-valor-secreto
